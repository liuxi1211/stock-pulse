{
  "factorKey": "BOLL",
  "displayName": "BOLL 布林带",
  "category": "OVERLAP",
  "description": "由中轨（MA）和上下 N 倍标准差通道构成",
  "params": [
    {
      "name": "timeperiod",
      "displayName": "周期",
      "type": "INT",
      "defaultValue": 20,
      "min": 1,
      "max": 500,
      "step": 1
    },
    {
      "name": "nbdevup",
      "displayName": "上轨标准差倍数",
      "type": "FLOAT",
      "defaultValue": 2.0,
      "min": 0.01,
      "max": 10.0,
      "step": 0.01
    },
    {
      "name": "nbdevdn",
      "displayName": "下轨标准差倍数",
      "type": "FLOAT",
      "defaultValue": 2.0,
      "min": 0.01,
      "max": 10.0,
      "step": 0.01
    },
    {
      "name": "matype",
      "displayName": "均线类型",
      "type": "ENUM",
      "defaultValue": 0,
      "enumValues": [
        {"value": 0, "label": "SMA 简单均线"},
        {"value": 1, "label": "EMA 指数均线"},
        {"value": 2, "label": "WMA 加权均线"},
        {"value": 3, "label": "DEMA 双指数均线"},
        {"value": 4, "label": "TEMA 三指数均线"},
        {"value": 5, "label": "TRIMA 三角均线"},
        {"value": 6, "label": "KAMA 考夫曼自适应均线"},
        {"value": 7, "label": "MESA 自适应均线"},
        {"value": 8, "label": "T3 三重指数均线"}
      ]
    }
  ],
  "inputs": ["close"],
  "multiOutput": true,
  "outputLabels": ["上轨", "中轨", "下轨"],
  "defaultOutputIndex": 0,
  "lookbackHint": "timeperiod - 1",
  "lookbackDefault": 19
}
