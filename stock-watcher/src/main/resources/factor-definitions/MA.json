{
  "factorKey": "MA",
  "displayName": "MA 移动均线",
  "category": "OVERLAP",
  "description": "对数据取 N 周期移动平均值，支持通过 matype 选择均线类型",
  "params": [
    {
      "name": "timeperiod",
      "displayName": "周期",
      "type": "INT",
      "defaultValue": 5,
      "min": 1,
      "max": 500,
      "step": 1
    },
    {
      "name": "matype",
      "displayName": "均线类型",
      "type": "ENUM",
      "defaultValue": 0,
      "enumValues": [
        {"value": 0, "label": "SMA 简单均线"},
        {"value": 1, "label": "EMA 指数均线"},
        {"value": 2, "label": "WMA 加权均线"},
        {"value": 3, "label": "DEMA 双指数均线"},
        {"value": 4, "label": "TEMA 三指数均线"},
        {"value": 5, "label": "TRIMA 三角均线"},
        {"value": 6, "label": "KAMA 考夫曼自适应均线"},
        {"value": 7, "label": "MESA 自适应均线"},
        {"value": 8, "label": "T3 三重指数均线"}
      ]
    }
  ],
  "inputs": ["close"],
  "multiOutput": false,
  "outputLabels": [],
  "defaultOutputIndex": 0,
  "lookbackHint": "timeperiod - 1",
  "lookbackDefault": 4
}
