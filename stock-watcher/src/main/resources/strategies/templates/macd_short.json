{
  "strategy_id": null,
  "name": "MACD短线策略",
  "description": "MACD柱+RSI双确认短线信号",
  "scope": "single",
  "category": "TECHNICAL",
  "tags": ["MACD", "短线"],
  "tunable_params": [
    {"name": "fastperiod", "type": "int", "default": 12, "min": 3, "max": 30, "step": 1, "description": "MACD 快线周期", "bind_to": "MACD.fastperiod"},
    {"name": "slowperiod", "type": "int", "default": 26, "min": 10, "max": 60, "step": 1, "description": "MACD 慢线周期", "bind_to": "MACD.slowperiod"},
    {"name": "signalperiod", "type": "int", "default": 9, "min": 3, "max": 30, "step": 1, "description": "MACD 信号线周期", "bind_to": "MACD.signalperiod"},
    {"name": "rsi_period", "type": "int", "default": 14, "min": 5, "max": 40, "step": 1, "description": "RSI 周期", "bind_to": "RSI.timeperiod"}
  ],
  "screen_config": {
    "universe": {
      "pool": "manual",
      "stocks": ["510300.SH"]
    }
  },
  "trading_config": {
    "signals": {
      "buy": {
        "operator": "AND",
        "conditions": [
          {
            "type": "compare",
            "left": { "factor": "MACD", "output_index": 2 },
            "comparator": ">",
            "right": { "value": 0 }
          },
          {
            "type": "compare",
            "left": { "factor": "RSI", "params": { "timeperiod": 14 } },
            "comparator": "<",
            "right": { "value": 70 }
          }
        ]
      },
      "sell": {
        "operator": "OR",
        "conditions": [
          {
            "type": "compare",
            "left": { "factor": "MACD", "output_index": 2 },
            "comparator": "<",
            "right": { "value": 0 }
          },
          {
            "type": "compare",
            "left": { "factor": "RSI", "params": { "timeperiod": 14 } },
            "comparator": ">",
            "right": { "value": 80 }
          }
        ]
      }
    },
    "position_sizing": {
      "method": "order_target_percent",
      "target": 0.8
    },
    "exit": {
      "bracket": {
        "use_atr_stop": true,
        "atr_period": 14,
        "atr_multiplier": 2.0
      }
    }
  },
  "backtest_config": {
    "initial_cash": 100000,
    "broker_profile": "cn_stock_miniqmt",
    "t_plus_one": true,
    "lot_size": 100,
    "warmup_period": 35,
    "history_depth": 60
  }
}
