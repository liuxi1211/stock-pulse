{
  "strategy_id": null,
  "name": "景气度盈利动量",
  "description": "以盈利同比高增+收入同比高增为核心，ROE 把关质量，赚景气度超预期的钱。A 股成长投资核心打法，机构主流选股框架。景气度变化快，月度跟踪调仓。",
  "category": "FUNDAMENTAL",
  "tags": ["景气度", "盈利动量", "成长"],
  "screen_config": {
    "universe": { "pool": "csi500" },
    "factor": { "method": "composite", "weights": { "PROFIT_YOY": 0.5, "REVENUE_YOY": 0.3, "ROE_TTM": 0.2 } },
    "filter": {
      "conditions": {
        "operator": "AND",
        "conditions": [
          { "type": "compare", "left": { "factor": "PROFIT_YOY" }, "comparator": ">", "right": { "value": 20 } },
          { "type": "compare", "left": { "factor": "REVENUE_YOY" }, "comparator": ">", "right": { "value": 10 } },
          { "type": "compare", "left": { "factor": "ROE_TTM" }, "comparator": ">", "right": { "value": 8 } },
          { "type": "compare", "left": { "factor": "PE_TTM" }, "comparator": ">", "right": { "value": 0 } },
          { "type": "compare", "left": { "factor": "PE_TTM" }, "comparator": "<", "right": { "value": 60 } },
          { "type": "compare", "left": { "factor": "DEBT_TO_ASSETS" }, "comparator": "<", "right": { "value": 70 } }
        ]
      },
      "exclude_st": true,
      "exclude_suspended": true,
      "exclude_limit_up": true,
      "min_list_days": 250
    },
    "portfolio": { "top_n": 20, "max_weight_per_symbol": 0.08, "cash_reserve_pct": 0.1 }
  },
  "trading_config": {
    "rebalance": {
      "frequency": "monthly",
      "trigger": "first",
      "weight_mode": "equal",
      "reject_limit_up_on_buy": true,
      "reject_limit_down_on_sell": true
    },
    "exit": { "bracket": { "stop_loss_pct": 0.10, "take_profit_pct": 0.35 } }
  },
  "backtest_config": {
    "initial_cash": 1000000,
    "broker_profile": "cn_stock_miniqmt",
    "t_plus_one": true,
    "slippage": { "type": "percent", "value": 0.002 },
    "lot_size": 100,
    "warmup_period": 0,
    "history_depth": 60,
    "volume_limit_pct": 0.2
  }
}
